# Copy this file to .env (same directory) to override versions used by docker compose
# Lines beginning with # are comments.
# KIND_VERSION: Version of kind binary to download. See: https://github.com/kubernetes-sigs/kind/releases
KIND_VERSION=v0.23.0
# KUBECTL_VERSION: Specific Kubernetes version (e.g. v1.31.1) or 'stable' to always fetch the latest stable
KUBECTL_VERSION=stable

