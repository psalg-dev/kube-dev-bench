{
  "name": "kube-dev-bench-e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node ./scripts/run-playwright.mjs test",
    "test:headed": "node ./scripts/run-playwright.mjs test --headed",
    "test:debug": "node ./scripts/run-playwright.mjs test --debug",
    "test:registry": "node ./scripts/run-playwright.mjs test -c playwright.registry.config.ts",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0"
  }
}
