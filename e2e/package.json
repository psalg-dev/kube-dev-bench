{
  "name": "kube-dev-bench-e2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:dev": "E2E_KEEP_ALIVE=1 playwright test",
    "browsers": "playwright install",
    "infra:start": "docker compose -f ../kind/docker-compose.yml up -d && echo 'KinD manager started. Run wails dev from repo root separately.'",
    "infra:stop": "docker compose -f ../kind/docker-compose.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3"
  }
}
