# Normalize line endings (avoid CRLF breaking /bin/sh scripts inside compose commands)
* text=auto

# Force LF for shell, yaml, docker, js, jsx, css
*.sh        text eol=lf
*.bash      text eol=lf
*.env       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile  text eol=lf
kind/docker-compose.yml text eol=lf

# Keep binaries untouched
*.png binary
*.ico binary
*.exe binary
*.dll binary

