pre-wrap; word-break: break-word; }\n    .gh-notification__close {\n      grid-area: close;\n      background: transparent;\n      border: none;\n      color: var(--gh-text-muted, #8b949e);\n      cursor: pointer;\n      font-size: 18px;\n      padding: 0 4px;\n    }\n    .gh-notification__close:hover { color: var(--gh-text, #c9d1d9); }\n\n    .gh-notification__progress {\n      grid-area: progress;\n      height: 3px;\n      background: currentColor;\n      opacity: 0.9;\n      border-bottom-left-radius: 6px;\n      border-bottom-right-radius: 6px;\n      transform-origin: left center;\n      width: 100%;\n    }\n\n    /* Type themes aligned with GitHub dark */\n    .gh-notification--success {\n      border-color: #2ea043;\n      color: #3fb950; /* success fg */\n      background: rgba(46, 160, 67, 0.5);\n    }\n    .gh-notification--error {\n      border-color: #f85149;\n      color: #f85149; /* danger fg */\n      background: rgba(248, 81, 73, 0.5);\n    }\n    .gh-notification--warning {\n      border-color: #d29922;\n      color: #d29922; /* attention fg */\n      background: rgba(210, 153, 34, 0.5);\n    }\n  "]],[[46,68]],["BODY",{},[[46,69]],["DIV",{"id":"app"},["DIV",{"__playwright_scroll_left_":"82","id":"layout"},[[27,4]],["MAIN",{"id":"maincontent"},[[46,202]],["DIV",{"id":"main-panels"},[[18,101]],["DIV",{"id":"swarm-services-overview-react","class":"main-panel"},["DIV",{},[[28,7]],[[23,2]],["DIV",{"__playwright_target__":"call@36","class":"bottom-panel","style":"position: fixed; left: 0px; right: 0px; bottom: 0px; height: 360px; background: var(--gh-bg, #0d1117); color: var(--gh-text, #c9d1d9); border-top: 1px solid var(--gh-border, #30363d); box-shadow: rgba(0, 0, 0, 0.35) 0px -4px 20px; z-index: 200; display: flex; flex-direction: column; transition: height 0.12s ease-out;"},[[22,3]],[[18,104]],["DIV",{"style":"flex: 1 1 0%; min-height: 0px; position: relative; overflow: hidden;"},["DIV",{"style":"position: absolute; inset: 0px; display: flex; flex-d