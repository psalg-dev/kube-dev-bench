pre-wrap; word-break: break-word; }\n    .gh-notification__close {\n      grid-area: close;\n      background: transparent;\n      border: none;\n      color: var(--gh-text-muted, #8b949e);\n      cursor: pointer;\n      font-size: 18px;\n      padding: 0 4px;\n    }\n    .gh-notification__close:hover { color: var(--gh-text, #c9d1d9); }\n\n    .gh-notification__progress {\n      grid-area: progress;\n      height: 3px;\n      background: currentColor;\n      opacity: 0.9;\n      border-bottom-left-radius: 6px;\n      border-bottom-right-radius: 6px;\n      transform-origin: left center;\n      width: 100%;\n    }\n\n    /* Type themes aligned with GitHub dark */\n    .gh-notification--success {\n      border-color: #2ea043;\n      color: #3fb950; /* success fg */\n      background: rgba(46, 160, 67, 0.5);\n    }\n    .gh-notification--error {\n      border-color: #f85149;\n      color: #f85149; /* danger fg */\n      background: rgba(248, 81, 73, 0.5);\n    }\n    .gh-notification--warning {\n      border-color: #d29922;\n      color: #d29922; /* attention fg */\n      background: rgba(210, 153, 34, 0.5);\n    }\n  "]],[[57,68]],["BODY",{},[[57,69]],["DIV",{"id":"app"},["DIV",{"__playwright_scroll_left_":"46","id":"layout"},[[24,22]],["MAIN",{"id":"maincontent"},[[57,202]],[[1,11]],["DIV",{"id":"gh-notification-container"},["DIV",{"class":"gh-notification gh-notification--success"},"\n    ",["DIV",{"class":"gh-notification__icon","aria-hidden":"true"},"✓"],"\n    ",["DIV",{"class":"gh-notification__text","role":"status"},"Downloaded file"],"\n    ",["BUTTON",{"class":"gh-notification__close","aria-label":"Dismiss"},"×"],"\n    ",["DIV",{"class":"gh-notification__progress","style":"transition: width 3000ms linear;"}],"\n  "]]],[[53,241]]]],[[57,212]],[[57,213]],[[57,214]],[[57,215]]]],"viewport":{"width":1280,"height":720},"timestamp":635571.236,"wallTime":1767870192197,"collectionTime":9.699999999953434,"resourceOverrides":[],"isMainFrame":true}}
