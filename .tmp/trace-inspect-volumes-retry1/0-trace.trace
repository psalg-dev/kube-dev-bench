 0;\n  font-size: 1.1rem;\n  font-weight: 600;\n  color: #e0e0e0;\n}\n\n.rules-header p {\n  margin: 0;\n  color: #808080;\n  font-size: 0.85rem;\n}\n\n.rules-list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.rule-card {\n  background-color: #2a2a2a;\n  border: 1px solid #3a3a3a;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.rule-header {\n  padding: 12px 16px;\n  background-color: #252525;\n  border-bottom: 1px solid #3a3a3a;\n}\n\n.host-badge {\n  font-size: 0.95rem;\n  font-weight: 500;\n  color: #64b5f6;\n}\n\n.paths-table {\n  width: 100%;\n  border-collapse: collapse;\n}\n\n.paths-table th {\n  padding: 10px 16px;\n  text-align: left;\n  font-size: 0.8rem;\n  font-weight: 600;\n  color: #808080;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  background-color: #252525;\n  border-bottom: 1px solid #3a3a3a;\n}\n\n.paths-table td {\n  padding: 12px 16px;\n  font-size: 0.9rem;\n  color: #e0e0e0;\n  border-bottom: 1px solid #333;\n}\n\n.paths-table tr:last-child td {\n  border-bottom: none;\n}\n\n.path-cell code {\n  background-color: #1e1e1e;\n  padding: 2px 8px;\n  border-radius: 4px;\n  font-family: 'JetBrains Mono', 'Fira Code', monospace;\n  font-size: 0.85rem;\n}\n\n.path-type-badge {\n  display: inline-block;\n  padding: 2px 8px;\n  border-radius: 4px;\n  font-size: 0.75rem;\n  font-weight: 500;\n  background-color: rgba(156, 39, 176, 0.2);\n  color: #ce93d8;\n}\n\n.service-cell {\n  font-weight: 500;\n}\n\n.port-cell {\n  font-family: 'JetBrains Mono', 'Fira Code', monospace;\n  font-size: 0.85rem;\n}\n\n.no-paths {\n  text-align: center;\n  color: #808080;\n  font-style: italic;\n}\n\n.tls-section {\n  margin-top: 20px;\n  padding: 16px;\n  background-color: rgba(76, 175, 80, 0.1);\n  border: 1px solid rgba(76, 175, 80, 0.2);\n  border-radius: 8px;\n}\n\n.tls-section h4 {\n  margin: 0 0 12px 0;\n  font-size: 0.95rem;\n  font-weight: 600;\n  color: #81c784;\n}\n\n.tls-list {\n  display: flex;\n  flex-direction: column;